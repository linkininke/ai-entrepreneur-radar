# Environment
APP_ENV=development

# PostgreSQL
POSTGRES_USER=ai_radar
POSTGRES_PASSWORD=change_me
POSTGRES_DB=ai_radar

# Backend
DATABASE_URL=postgresql://ai_radar:change_me@postgres:5432/ai_radar
# DeepSeek API（分析 analyze / 机会 opportunity / 翻译 共用此 Key）
LLM_API_KEY=
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat
LLM_DEFAULT_LOCALE=zh-CN

# 若容器内访问 LLM API 出现 SSL/超时，配置宿主机代理（Windows Docker 用 host.docker.internal）
# HTTP_PROXY=http://host.docker.internal:7890
# HTTPS_PROXY=http://host.docker.internal:7890
# LLM_REQUEST_RETRIES=3

# Crawl / Data Sources
CRAWL_SOURCES=hackernews,github,rss,producthunt
GITHUB_API_TOKEN=
RSS_FEED_URLS=https://techcrunch.com/feed/,https://feeds.arstechnica.com/arstechnica/technology-lab

# Scheduler / Worker
SCHEDULER_ENABLED=true
CRAWL_INTERVAL_MINUTES=60
PIPELINE_INTERVAL_MINUTES=120
CRAWL_BATCH_SIZE=20
ANALYZE_BATCH_SIZE=5
OPPORTUNITY_BATCH_SIZE=5
